# PostgreSQL
POSTGRES_USER=adpilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=adpilot
DATABASE_URL=postgresql+asyncpg://adpilot:changeme@postgres:5432/adpilot

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=adpilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security
MASTER_ENCRYPTION_KEY=  # 32 bytes base64-encoded, generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID= # получить через @userinfobot

# Environment
ENVIRONMENT=development
DEBUG=true
TENANT_TIMEZONE=Europe/Moscow  # pytz timezone string, e.g. Europe/Kiev, Asia/Almaty
GIT_TOKEN=  # your GitHub personal access token

